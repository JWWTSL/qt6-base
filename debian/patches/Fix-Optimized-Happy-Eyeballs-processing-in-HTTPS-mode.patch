+// compatible. If state is neither IPv4 nor IPv6 (e.g. still in the racing
+// phase), we consider it compatible to avoid premature filtering.
+bool QHttpNetworkConnectionPrivate::stateMatchesPreference(
+    NetworkLayerPreferenceState state,
+    QAbstractSocket::NetworkLayerProtocol preference)
+{
+    if (preference == QAbstractSocket::AnyIPProtocol)
+        return true;
+    switch (state) {
+    case IPv4:
+        return preference == QAbstractSocket::IPv4Protocol;
+    case IPv6:
